// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String      @id @default(cuid())
  githubUsername   String      @unique
  leetcodeUsername String?     @unique              // Optional initially
  
  // Relationships
  groups           Group[]     
  dailyStats       DailyStat[] 
  
  createdAt        DateTime    @default(now())
}

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique  
  
  // Relationships
  members    User[]   
  
  createdAt  DateTime @default(now())
}

model DailyStat {
  id               String   @id @default(cuid())
  
  // Linking this stat to a specific User
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  // The actual data we scrape
  date             DateTime @default(now())
  githubCommits    Int      @default(0)
  leetcodeSolved   Int      @default(0)

  // CRITICAL: Ensures a user only gets ONE record per day
  @@unique([userId, date]) 
}