generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. AUTH.JS CORE MODELS 
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// 2. THE USER MODEL 
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // App-Specific Identity
  githubUsername   String?  @unique
  leetcodeUsername String?  @unique

  // Cached All-Time Totals (For the Global All-Time Leaderboard)
  githubTotal      Int      @default(0)
  leetcodeTotal    Int      @default(0)

  // Relationships
  accounts       Account[]
  sessions       Session[]
  groups         Group[]             // A user can be in many groups
  contributions  DailyContribution[] // The Heatmap Data
}

// ==========================================
// 3. GROUPS (For College Squads)
// ==========================================
model Group {
  id          String   @id @default(cuid())
  name        String   @unique 
  description String?
  createdAt   DateTime @default(now())

  members     User[]   
}

// ==========================================
// 4. THE HEATMAP DATA (Time-Series Data)
// ==========================================
model DailyContribution {
  id          String   @id @default(cuid())
  userId      String
  
  // "GITHUB" or "LEETCODE"
  platform    String   
  
  // Stored as "YYYY-MM-DD" (e.g., "2026-03-04")
  dateString  String   
  
  // The count for this specific day
  count       Int      @default(0)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CRITICAL: Prevents duplicate rows for the same day/platform combination
  @@unique([userId, platform, dateString])
  
  // Indexing makes Monday-to-Monday queries lightning fast
  @@index([dateString]) 
}