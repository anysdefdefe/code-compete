// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String      @id @default(cuid())

// Standard Auth.js fields (GitHub will fill these automatically)
  name             String?
  email            String?     @unique
  emailVerified    DateTime?
  image            String?

  githubUsername   String?     @unique // Changed to optional to prevent login crashes
  leetcodeUsername String?     @unique              // Optional initially
  
  // Relationships
  accounts         Account[]   // Required for Auth.js
  sessions         Session[]   // Required for Auth.js
  groups           Group[]     
  dailyStats       DailyStat[] 
  
  createdAt        DateTime    @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique  
  
  // Relationships
  members    User[]   
  
  createdAt  DateTime @default(now())
}

model DailyStat {
  id               String   @id @default(cuid())
  
  // Linking this stat to a specific User
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  
  // The actual data we scrape
  date             DateTime @default(now())
  githubCommits    Int      @default(0)
  leetcodeSolved   Int      @default(0)

  // CRITICAL: Ensures a user only gets ONE record per day
  @@unique([userId, date]) 
}